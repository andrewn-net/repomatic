{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "version": {
            "type": "integer"
        },
        "scenarios": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "name",
                    "template_repo",
                    "default_repo_name",
                    "start_tag"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "tool": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "template_repo": {
                        "type": "string"
                    },
                    "default_repo_name": {
                        "type": "string"
                    },
                    "start_tag": {
                        "type": "string"
                    },
                    "slack_apps": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                },
                                "install_url": {
                                    "type": "string",
                                    "format": "uri"
                                },
                                "docs_url": {
                                    "type": "string",
                                    "format": "uri"
                                }
                            }
                        }
                    },
                    "prompts": {
                        "type": "object",
                        "properties": {
                            "bug_fix": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "feature": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "runbook": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}